{
  "name": "@efthemiosprime/polyx",
  "version": "0.0.11",
  "description": "A minimal functional utilities based on category theory",
  "type": "module",
  "main": "./dist/umd/polyx.umd.js",
  "module": "./dist/esm/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/umd/polyx.umd.js"
    },
    "./core": {
      "types": "./types/core.d.ts",
      "import": "./dist/esm/core.js"
    },
    "./data": {
      "types": "./types/data.d.ts",
      "import": "./dist/esm/data.js"
    },
    "./dom": {
      "types": "./types/dom.d.ts",
      "import": "./dist/esm/dom.js"
    },
    "./async": {
      "types": "./types/async.d.ts",
      "import": "./dist/esm/async.js"
    },
    "./state": {
      "types": "./types/state.d.ts",
      "import": "./dist/esm/state.js"
    },
    "./advanced": {
      "import": "./dist/esm/advanced.js"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "npm run build:all",
    "build:all": "npm run build:es && npm run build:umd",
    "build:es": "cross-env FORMAT=es vite build",
    "build:umd": "cross-env FORMAT=umd vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "push": "npm publish --access public"
  },
  "keywords": [
    "functional",
    "programming",
    "category",
    "theory",
    "monad",
    "functor",
    "applicative",
    "compose",
    "either",
    "maybe",
    "validation",
    "io",
    "task"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.7",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "terser": "^5.39.0",
    "typescript": "^7.0.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/efthemiosprime/polyx.git"
  },
  "bugs": {
    "url": "https://github.com/efthemiosprime/polyx/issues"
  },
  "homepage": "https://github.com/efthemiosprime/polyx#readme"
}
